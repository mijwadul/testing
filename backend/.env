# ============================================================
# PT. Kusuma Samudera Berkah — Environment Variables
# ============================================================

# --- Aplikasi ---
APP_NAME="PT. Kusuma Samudera Berkah API"
DEBUG=true

# --- Keamanan ---4b7e23ce6a77275280d800750c9d56091a250669b4b2e6ef98230a2b1edab446
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (Development - SQLite) ---
# CATATAN: sql_app.db adalah database lama yang sudah berisi data.
# Ganti ke bina_erp.db jika ingin mulai dari database baru.
DATABASE_URL=sqlite:///./sql_app.db

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Admin Default ---
# Akun ini dibuat OTOMATIS hanya jika belum ada di database
# CATATAN: Email ini adalah akun admin default pertama.
# Jika ingin memakai email lama (mijwadul@kusuma.com), ganti di sini.
DEFAULT_ADMIN_EMAIL=admin@kusuma.com
DEFAULT_ADMIN_PASSWORD=GantiPassword123!
