# ============================================================
# PT. Kusuma Samudera Berkah — Environment Variables
# Salin file ini menjadi .env dan isi nilainya sebelum menjalankan server
# ============================================================

# --- Aplikasi ---
APP_NAME="PT. Kusuma Samudera Berkah API"
# Set ke false di production!
DEBUG=false

# --- Keamanan ---
# WAJIB diisi: generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GANTI_DENGAN_SECRET_KEY_YANG_AMAN_DAN_PANJANG
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
# Development (SQLite - lokal):
DATABASE_URL=sqlite:///./bina_erp.db

# Production (PostgreSQL - uncomment dan sesuaikan):
# DATABASE_URL=postgresql://user:password@localhost:5432/kusuma_erp

# --- CORS ---
# Pisahkan dengan koma jika ada lebih dari satu origin
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Admin Default ---
# Akun ini dibuat OTOMATIS hanya jika belum ada di database
# PENTING: Ganti password setelah login pertama!
DEFAULT_ADMIN_EMAIL=admin@kusuma.com
DEFAULT_ADMIN_PASSWORD=GantiPassword123!
